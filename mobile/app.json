{
  "expo": {
    "name": "OfflineBeats",
    "slug": "offlinebeats",
    "version": "2.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#121212",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.offlinebeats.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ],
        "NSMicrophoneUsageDescription": "Not used",
        "NSAppleMusicUsageDescription": "Access your music library",
        "NSPhotoLibraryUsageDescription": "Save downloaded music files",
        "NSPhotoLibraryAddUsageDescription": "Save downloaded music files"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121212"
      },
      "package": "com.offlinebeats.app",
      "versionCode": 11,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "plugins": [
      "expo-av",
      "expo-asset",
      "expo-sqlite",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow OfflineBeats to save music files to your device.",
          "savePhotosPermission": "Allow OfflineBeats to save music files to your device.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1DB954"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "453b1e1f-a1e2-46af-9a40-419e9770dc05"
      }
    },
    "owner": "sumit-songara"
  }
}
